[Unit]
Description=OverVK Tunnel Server
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/var/overvk-server
ExecStart=/var/overvk-server/overvk /var/overvk-server/config.yaml
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
